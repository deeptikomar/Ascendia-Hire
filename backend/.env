# Server
PORT=3000

# Comma-separated list of allowed origins for CORS (frontend URL(s))
FRONTEND_URL=http://localhost:3000

# Secret used to sign JWTs. Generate a strong random value for real deployments, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev_only_secret_do_not_use_in_production_5f8a2c1e9b3d
JWT_EXPIRES_IN=7d
