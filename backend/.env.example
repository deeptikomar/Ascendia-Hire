# Server
PORT=3000

# Comma-separated list of allowed origins for CORS (frontend URL(s))
FRONTEND_URL=http://localhost:3000

# Secret used to sign JWTs. Generate a strong random value for real deployments, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
